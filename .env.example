# Supabase — server-only. The browser never reads these (no NEXT_PUBLIC_ prefix).
# Project values live in Supabase dashboard → Project Settings → API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated lowercase emails matched against auth.users.email.
# Holders gain access to /admin/tickets to confirm WhatsApp payments.
ADMIN_EMAILS=
